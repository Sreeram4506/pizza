{
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "https://pizzabackend-qzi1.onrender.com/api/:path*"
        },
        {
            "source": "/socket.io/:path*",
            "destination": "https://pizzabackend-qzi1.onrender.com/socket.io/:path*"
        },
        {
            "source": "/uploads/:path*",
            "destination": "https://pizzabackend-qzi1.onrender.com/uploads/:path*"
        },
        {
            "source": "/((?!api|socket.io|uploads).*)",
            "destination": "/index.html"
        }
    ]
}